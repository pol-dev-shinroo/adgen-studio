# Apify API token (Settings > Integrations in the Apify console)
APIFY_TOKEN=

# Google OAuth2 client (Web application type) — see README "Google Sheets auth"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# One-time: run `node scripts/google-auth.js` and paste the refresh token here
GOOGLE_REFRESH_TOKEN=

# Target Google Sheet: the long ID from the spreadsheet URL, and the tab name
SHEET_ID=
SHEET_TAB_NAME=시트1

# Optional: Drive folder ID for the media archive root. Leave empty to let
# the app find/create a folder named "AdGen Media Archive" automatically.
DRIVE_FOLDER_ID=

# Origin allowed to call this API (the Vite dev server by default)
CORS_ORIGIN=http://localhost:3000

PORT=4000
